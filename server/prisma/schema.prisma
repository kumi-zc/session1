generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("COUNTER") // ADMIN, COUNTER
  status    String   @default("APPROVED") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks         StockTakingTask[] @relation("TaskAssignee")
  movements     StockMovement[]   @relation("MovementOperator")
}

model Product {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  name        String
  category    String?
  unit        String   @default("个")
  costPrice   Float    @default(0)
  sellPrice   Float    @default(0)
  safetyStock Int      @default(0)
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock       Stock?
  takingItems StockTakingItem[]
  movements   StockMovement[]
}

model Stock {
  id        Int     @id @default(autoincrement())
  productId Int     @unique
  quantity  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model StockTakingTask {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  type        String   @default("FULL") // FULL, CATEGORY, AREA
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, REVIEWING, COMPLETED, ADJUSTED
  assigneeId  Int?
  area        String?
  plannedDate DateTime @default(now())
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignee User?              @relation("TaskAssignee", fields: [assigneeId], references: [id])
  items    StockTakingItem[]
}

model StockTakingItem {
  id       Int     @id @default(autoincrement())
  taskId   Int
  productId Int
  systemQty Int
  actualQty Int?
  status   String  @default("PENDING") // PENDING, COUNTED, REVIEWED

  task    StockTakingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([taskId, productId])
}

model StockMovement {
  id         Int      @id @default(autoincrement())
  productId  Int
  type       String                // IN, OUT, STOCK_IN, STOCK_OUT
  quantity   Int
  source     String?
  operatorId Int?
  remark     String?
  createdAt  DateTime @default(now())

  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  operator User?   @relation("MovementOperator", fields: [operatorId], references: [id])
}
